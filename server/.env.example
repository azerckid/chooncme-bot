ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# 이메일 알림 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=앱비밀번호

# 알림 이메일 본문에 삽입되는 허브 접속 URL (미설정 시 localhost:3001)
HUB_PUBLIC_URL=https://chooncme.xyz

# 허브 서버 URL — NEAR 이벤트 전달용 (미설정 시 허브 알림 skip)
HUB_SERVER_URL=https://hub.chooncme.xyz

# v0.8 NEAR 연동 (미설정 시 온체인 기록 skip, 기존 기능 영향 없음)
NEAR_NETWORK=testnet
NEAR_CONTRACT_ID=chooncme.testnet
NEAR_ACCOUNT_ID=chooncme-server.testnet
NEAR_PRIVATE_KEY=ed25519:your_function_call_private_key_here
